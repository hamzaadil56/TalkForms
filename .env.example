# ── Required ──────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# Neon Postgres connection string
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Strong random secret — generate with: openssl rand -hex 32
JWT_SECRET=change_me_to_a_strong_random_secret

# ── Bootstrap (first run only) ────────────────────────────────────────────────
AGENTIC_ADMIN_EMAIL=admin@yourdomain.com
AGENTIC_ADMIN_PASSWORD=change_me
AGENTIC_DEFAULT_ORG_NAME=My Workspace

# ── CORS (comma-separated list of allowed frontend origins) ───────────────────
# Example: CORS_ORIGINS=["https://yourdomain.com"]
CORS_ORIGINS=["https://yourdomain.com"]

# ── Optional ──────────────────────────────────────────────────────────────────
# OPENAI_AGENTS_DISABLE_TRACING=true
# ACCESS_TOKEN_TTL_MIN=60
# PUBLIC_SESSION_TTL_HOURS=8
# LOG_LEVEL=INFO
